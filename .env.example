# --- Taller Duke Local Configuration ---
# All data is stored locally in 'taller.db' (SQLite)

# Run 'openssl rand -hex 32' to generate a secure JWT secret
JWT_SECRET=generate-a-long-random-string-here

# Admin Initial Credentials
ADMIN_USER=admin
ADMIN_PASS=ChangeMeImmediately
ADMIN_NAME=Taller Admin

# Email Configuration (SMTP) - Optional
# For Gmail, use an "App Password" (https://myaccount.google.com/apppasswords)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
